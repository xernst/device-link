# Device Link Configuration
# Copy to ~/.device-link/config and fill in your values.

# --- Helper hostnames (Tailscale names or IPs) ---
DEVICE_LINK_LEFT_HOST=helper-left
DEVICE_LINK_RIGHT_HOST=helper-right

# --- SSH user (same on all machines) ---
DEVICE_LINK_USER=yourusername

# --- Default project name (or set per-session) ---
# DEVICE_LINK_PROJECT=my-app

# --- Default mode: pipeline | direct | ollama ---
DEVICE_LINK_MODE=pipeline

# --- API Keys ---
# Tier 1: ChatGPT (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Tier 2: Claude (get from https://console.anthropic.com/)
# Only needed if running Claude via API. If using `claude` CLI, it uses its own auth.
# ANTHROPIC_API_KEY=sk-ant-...

# --- Model Selection ---
# OpenAI model for Tier 1 reasoning
DEVICE_LINK_OPENAI_MODEL=gpt-4o

# Ollama models for Tier 3 execution
DEVICE_LINK_OLLAMA_MODEL_LEFT=qwen2.5-coder:7b
DEVICE_LINK_OLLAMA_MODEL_RIGHT=llama3.1:8b
